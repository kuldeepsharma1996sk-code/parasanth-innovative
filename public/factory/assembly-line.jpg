<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a1a"/>
      <stop offset="100%" style="stop-color:#2a2a2a"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#bgGrad)"/>
  <!-- Factory building silhouette -->
  <rect x="100" y="400" width="400" height="500" fill="#252525"/>
  <rect x="520" y="300" width="350" height="600" fill="#2a2a2a"/>
  <rect x="890" y="350" width="300" height="550" fill="#252525"/>
  <rect x="1210" y="280" width="400" height="620" fill="#2a2a2a"/>
  <rect x="1630" y="400" width="200" height="500" fill="#252525"/>
  <!-- Windows -->
  <rect x="150" y="450" width="80" height="60" fill="#3a3a3a"/>
  <rect x="270" y="450" width="80" height="60" fill="#3a3a3a"/>
  <rect x="150" y="550" width="80" height="60" fill="#3a3a3a"/>
  <rect x="270" y="550" width="80" height="60" fill="#3a3a3a"/>
  <rect x="570" y="350" width="100" height="80" fill="#3a3a3a"/>
  <rect x="720" y="350" width="100" height="80" fill="#3a3a3a"/>
  <rect x="570" y="470" width="100" height="80" fill="#3a3a3a"/>
  <rect x="720" y="470" width="100" height="80" fill="#3a3a3a"/>
  <!-- Red accent line -->
  <rect x="0" y="900" width="1920" height="4" fill="#e82127"/>
  <!-- Text -->
  <text x="960" y="200" text-anchor="middle" fill="#ffffff" font-family="Arial, sans-serif" font-size="48" font-weight="bold" opacity="0.3">MANUFACTURING FACILITY</text>
</svg>
